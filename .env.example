# 이 파일을 복사해 .env 로 만들고 값을 채우세요.  →  cp .env.example .env
# .env 는 절대 GitHub 에 올리지 마세요(.gitignore 로 제외됨).

# Cloudflare 터널 토큰 (Zero Trust > Networks > Tunnels 에서 발급)
# 실제 값은 저장소 소유자에게 별도(메신저/비밀번호 관리자 등)로 안전하게 전달받으세요.
TUNNEL_TOKEN=

# (선택) 최초 실행 시 자동 생성되는 관리자 계정의 초기 비밀번호.
# 기존 data/data.json 을 함께 받아 배포하면 관리자 계정이 이미 있으므로 무시됩니다.
ADMIN_INITIAL_PW=
